generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  role      String   @default("USER")
  passwordHash String?
  createdAt DateTime @default(now())

  brokerName           String?
  apiKey               String?
  apiSecret            String?
  clientCode           String?
  requestToken         String?
  accessToken          String?
  accessTokenUpdatedAt DateTime?
  isPaperTrading       Boolean  @default(true)
  
  automationEnabled    Boolean  @default(false)
  activeStrategyId     String?
  engineState          String?
  
  StrategyLog StrategyLog[]
  orders      Order[]
}

model StrategyLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  strategyId String
  action     String
  symbol     String
  price      Float
  qty        Int
  status     String
  isSimulated Boolean @default(false)
  message    String?
  timestamp  DateTime @default(now())
}

model Order {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  symbol     String
  side       String   // BUY / SELL
  price      Float
  qty        Int

  type       String   @default("MARKET") // MARKET / LIMIT
  product    String   @default("MIS")    // MIS / CNC

  status     String   @default("FILLED") // FILLED / PENDING
  isSimulated Boolean @default(true)

  createdAt  DateTime @default(now())
}

model MarketDataConfig {
  id                 String   @id @default("GLOBAL")
  brokerName         String   @default("Kite")
  appKey             String
  appSecret          String
  clientCode         String?
  redirectUrl        String?
  requestToken       String?
  accessToken        String?
  accessTokenUpdatedAt DateTime?
  bankNiftyInstrumentToken Int @default(260105)
  isEnabled          Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model AdmissionLead {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  course    String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model AliceBlueLead {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  pan       String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}