// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  role      String   @default("USER")
  passwordHash String?
  createdAt DateTime @default(now())

  // Broker Credentials
  brokerName           String?
  apiKey               String?
  apiSecret            String?
  clientCode           String?
  requestToken         String?
  accessToken          String?
  accessTokenUpdatedAt DateTime?
  
  // Strategy Subscription Logs
  StrategyLog StrategyLog[]
}

model StrategyLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  strategyId String
  action     String   // "ENTRY_CALL", "ENTRY_PUT", "EXIT_TARGET", "EXIT_SL"
  symbol     String
  price      Float
  qty        Int
  status     String   // "SUCCESS", "FAILED"
  message    String?
  timestamp  DateTime @default(now())
}

model MarketDataConfig {
  id                 String   @id @default("GLOBAL")
  brokerName         String   @default("Kite")
  appKey             String
  appSecret          String
  clientCode         String?
  redirectUrl        String?
  requestToken       String?
  accessToken        String?
  accessTokenUpdatedAt DateTime?
  bankNiftyInstrumentToken Int @default(260105)
  isEnabled          Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}
model ContactInquiry {
  id        String   @id @default(uuid())
  name      String
  phone     String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model AdmissionLead {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String
  course    String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}
